PORT=3000
NODE_ENV=development
SUPABASE_URL=your_supabase_project_url
# Use SERVICE_ROLE_KEY on backend (NOT anon key) — it bypasses RLS safely on the server
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
FRONTEND_URL=https://your-frontend-url.vercel.app
# OneSignal Push Notifications (get from OneSignal dashboard > App Settings > Keys & IDs)
ONESIGNAL_APP_ID=109c1bae-e0a1-4b1c-a781-53f1ab90e9ec
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
# Aadhaar Verification (Surepass)
SUREPASS_API_TOKEN=your_surepass_token
SUREPASS_ENV=sandbox
# Email Verification (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM_ADDRESS=onboarding@resend.dev
